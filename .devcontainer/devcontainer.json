{
  "name": "KGeoGuessr",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspaces/KGeoGuessr",
  "remoteUser": "node",
  "forwardPorts": [
    3000
  ],
  "portsAttributes": {
    "3000": {
      "label": "Next.js dev server"
    }
  },
  "postCreateCommand": "sh -lc 'if [ ! -f .env.local ]; then cp .env.local.example .env.local; fi; npm ci'",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  }
}
